// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/**
 * User - Master Identity for SOC Analysts
 */
model User {
  id        String   @id @default(cuid())
  userId    String   @unique // e.g., 'AN-001'
  email     String   @unique
  name      String
  role      String   @default("analyst") // admin, manager, l1_analyst, l2_analyst, auditor, demo
  password  String   // PBKDF2-SHA256 hash (no default — must be set by seed or registration)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  cases     Case[]
}

/**
 * AuditLog - Forensic Activity Documentation
 * Records all critical administrative and technical actions.
 * Immutable by design — no update/delete operations.
 */
model AuditLog {
  id        String   @id @default(cuid())
  txHash    String   @unique // Forensic Signature generated by the forensicUtils
  timestamp DateTime @default(now())
  action    String   // e.g., 'FORCE_DISCONNECT', 'AUTH_LOGIN'
  category  String   // e.g., 'SECURITY', 'AUTH', 'SHIFT'
  details   String
  result    String   @default("SUCCESS")
  metadata  String?  // JSON String
  changes   String?  // JSON String (Diff before/after)

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([timestamp(sort: Desc)])
  @@index([txHash])
  @@index([category, timestamp(sort: Desc)])
  @@index([actorId, timestamp(sort: Desc)])
}

/**
 * Case - Incident Tracking & Investigation
 * Persists triage data from external sources like Wazuh.
 */
model Case {
  id                String   @id // Primary identifier (Alert ID)
  title             String?  // Human-readable case title
  timestamp         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  ruleId            String?
  ruleDescription   String
  severity          String?  // LOW, MEDIUM, HIGH, CRITICAL
  status            String   @default("open") // open, investigating, closed, escalated, false_positive
  category          String?

  initialAssessment String?
  evidence          String?
  actionTaken       String?
  recommendation    String?
  notes             String?

  analystId         String?
  analyst           User?    @relation(fields: [analystId], references: [id])

  history           String?  // JSON String Array
  metadata          String?  // JSON String (Alert Payload)

  @@index([status])
  @@index([analystId])
  @@index([timestamp(sort: Desc)])
}

/**
 * SystemSetting - Global Application Config
 */
model SystemSetting {
  key   String @id
  value String // JSON String
}

/**
 * Schedule - Operational Shift Rosters
 */
model Schedule {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  shiftType   String   // morning, afternoon, night
  personnel   String   // JSON string of user IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, shiftType])
}

/**
 * Attendance - Analyst Availability Tracking
 */
model Attendance {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  userId    String
  status    String   // present, sick, leave, holiday, standby
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, userId])
  @@index([userId])
}

/**
 * Presence - Real-time WebSocket session tracking
 */
model Presence {
  socketId  String   @id
  userId    String
  username  String
  role      String?
  page      String?
  ip        String?
  lastSeen  DateTime @default(now())

  @@index([userId])
}

/**
 * ActiveTeam - Personnel currently 'On-Duty' (Clocked In)
 */
model ActiveTeam {
  userId    String   @id
  name      String?
  role      String?
  joinedAt  DateTime @default(now())
  notes     String?
}
