BFF_PORT=8787
BFF_ALLOWED_ORIGIN=http://localhost:5173
BFF_STRICT_AUTH=false
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left empty, a random secret is generated per-instance (sessions won't persist across restarts).
BFF_AUTH_JWT_SECRET=

# Optional: configure upstreams on server side.
# If omitted, frontend can still send config payload from Settings page.
WAZUH_MANAGER_HOST=
WAZUH_MANAGER_PORT=55000
WAZUH_MANAGER_USER=
WAZUH_MANAGER_PASSWORD=
WAZUH_MANAGER_TOKEN=

WAZUH_INDEXER_HOST=
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=

OPENCTI_URL=
OPENCTI_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional frontend fallback / override.
# VITE_SOCOPS_BFF_URL=http://localhost:8787
# VITE_BFF_PROXY_TARGET=http://localhost:8787
